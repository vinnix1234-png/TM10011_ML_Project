#%% Class voor beste classifier selectie
class BestClassifierSelection: 
    def __init__(self, classifier_list, labels, features, scaler, feature_selection, k_fold, scoring_method):
        from sklearn.preprocessing import LabelEncoder
        
        # Variabelen opslaan in de class
        self.classifier_list = classifier_list
        self.X = features
        self.y = labels
        self.scaler = scaler
        self.feature_selection = feature_selection
        self.cv = k_fold
        self.scoring = scoring_method

        # Zet label om in getal, dus lipoma=0, liposarcoma=1
        self.label_encoder = LabelEncoder()
        self.y_encoded = self.label_encoder.fit_transform(self.y)

        # Resultaten opslaan
        self.results = {}

    def run_classifiers(self):
        from sklearn.pipeline import Pipeline
        from sklearn.model_selection import cross_val_score
        from sklearn.feature_selection import VarianceThreshold
        
        cleaner_variance = VarianceThreshold(threshold=0)

        for name, classifier in self.classifier_list.items():
            pipe = Pipeline([
                ("cleaner_var", cleaner_variance),
                ("scaler", self.scaler),
                ("feature selection", self.feature_selection),
                ("classifier", classifier)
            ])

            scores = cross_val_score(pipe, self.X, self.y_encoded, cv=self.cv, scoring=self.scoring)
            self.results[name] = scores.mean()

    def get_results(self):
        return sorted(self.results.items(), key=lambda x: x[1], reverse=True)


