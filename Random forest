#%% Clipper
class Clipper(BaseEstimator, TransformerMixin):
    def __init__(self, lower=0.01, upper=0.99):
        self.lower = lower
        self.upper = upper
    def fit(self, X, y=None):
        self.lower_bounds_ = np.quantile(X, self.lower, axis=0)
        self.upper_bounds_ = np.quantile(X, self.upper, axis=0)
        return self
    def transform(self, X):
        return np.clip(X, self.lower_bounds_, self.upper_bounds_)
    
    #%% Pipeline
# SelectKBest ipv SelectFromModel → minder leakage risico
pipeline = Pipeline([
    ("imputer",   SimpleImputer(strategy="median")),
    ("clipper",   Clipper(0.01, 0.99)),
    ("variance",  VarianceThreshold(threshold=0.0)),
    ("selection", SelectKBest(f_classif, k=20)),
    ("model",     RandomForestClassifier(random_state=42))
])

#%% Hyperparameters — bewust conservatief voor n=115
param_dist = {
    "selection__k":              [10, 15, 20],     
    "model__n_estimators":       [200, 300, 500],
    "model__max_depth":          [3, 4, 5],          
    "model__min_samples_split":  [10, 15, 20],        
    "model__min_samples_leaf":   [6, 8, 10],          
    "model__max_features":       ["sqrt", 0.2, 0.3],  
    "model__max_samples":        [0.7, 0.8],          
}

#%% Nested CV
inner_cv = RepeatedStratifiedKFold(n_splits=5, n_repeats=3, random_state=42)
outer_cv = RepeatedStratifiedKFold(n_splits=5, n_repeats=10, random_state=0)

search = RandomizedSearchCV(
    pipeline,
    param_distributions=param_dist,
    n_iter=30,
    cv=inner_cv,
    scoring="roc_auc",
    n_jobs=4,
    random_state=42
)

#%% Eerlijke performance schatting via outer CV
scores = cross_val_score(search, X, y, cv=outer_cv, scoring="roc_auc", n_jobs=4)

print(f"Nested CV ROC-AUC: {scores.mean():.3f} ± {scores.std():.3f}")