#%% Data Loading as a Pandas DataFrame
from worclipo.load_data import load_data

data = load_data()

print(f'The number of samples: {len(data.index)}')
print(f'The number of columns: {len(data.columns)}')

#%% Import packages
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.model_selection import RandomizedSearchCV, StratifiedKFold, LeaveOneOut
from sklearn.preprocessing import RobustScaler, LabelEncoder
from sklearn.feature_selection import VarianceThreshold
from sklearn.pipeline import Pipeline
from sklearn.base import BaseEstimator, TransformerMixin
from sklearn.metrics import roc_curve, auc

from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from xgboost import XGBClassifier

from sklearn.feature_selection import SelectKBest, f_classif, RFE, SelectFromModel
from sklearn.decomposition import PCA
from sklearn.base import clone

from scipy.stats import spearmanr

#%% Parameters defineren
y = data.iloc[:, 0]
X = data.iloc[:, 1:]

labelencoder = LabelEncoder()
y = labelencoder.fit_transform(y)  # 'lipoma' → 0, 'liposarcoma' → 1

classifiers = {
    "Logistic Regression": LogisticRegression(max_iter=20000, random_state=42, solver='saga'),
    "Random Forest": RandomForestClassifier(random_state=42),
    "XGBoost": XGBClassifier(random_state=42, eval_metric='logloss', verbosity=0, tree_method='hist')
}

hyperparameter_grid_logistic_regression = {
    'C': [0.0001, 0.001, 0.01, 0.1, 1, 10],
    'solver': ['saga'],
    'l1_ratio': [0.0, 0.005, 0.1, 0.3, 0.5, 0.9, 1.0]
}
hyperparameter_grid_random_forest = {
    'n_estimators': [200, 300, 500],
    'max_depth': [3, 4, 5],
    'min_samples_split': [2, 5, 10, 15, 20],
    'min_samples_leaf': [2, 4, 6, 8, 10],
    'max_features': ['sqrt', 0.2, 0.3],
    'max_samples': [0.7, 0.8]
}
hyperparameter_grid_xgboost = {
    'n_estimators': [50, 100, 200, 300],
    'learning_rate': [0.01, 0.05, 0.1],
    'gamma': [0, 0.1, 0.3, 0.5],
    'max_depth': [3, 4, 5],
    'subsample': [0.7, 0.8, 1.0]
}
hyperparameter_grids = {
    "Logistic Regression": hyperparameter_grid_logistic_regression,
    "Random Forest": hyperparameter_grid_random_forest,
    "XGBoost": hyperparameter_grid_xgboost
}

#%% Extra functies
def get_feature_selection_methods(classifier, clf_name):
    methods = {
        "None": None,
        "SelectKBest": SelectKBest(f_classif, k=10),
        "SelectFromModel": SelectFromModel(clone(classifier), max_features=10),
    }
    if clf_name == "Logistic Regression":
        methods["PCA"] = PCA(n_components=10)
        methods["RFE"] = RFE(clone(classifier), n_features_to_select=10, step=10)
    return methods


class Clipper(BaseEstimator, TransformerMixin):
    def __init__(self, lower=0.01, upper=0.99):
        self.lower = lower
        self.upper = upper

    def fit(self, X, y=None):
        self.lower_bounds = np.quantile(X, self.lower, axis=0)
        self.upper_bounds = np.quantile(X, self.upper, axis=0)
        return self

    def transform(self, X):
        return np.clip(X, self.lower_bounds, self.upper_bounds)


class CorrelationFilter(BaseEstimator, TransformerMixin):
    def __init__(self, threshold=0.8):
        self.threshold = threshold
        self.to_drop = None

    def fit(self, X, y=None):
        result = spearmanr(X)
        corr_matrix = np.abs(result.statistic)
        if corr_matrix.ndim == 0:
            self.to_drop = []
            return self
        upper = np.triu(corr_matrix, k=1)
        self.to_drop = np.where((upper > self.threshold).any(axis=0))[0].tolist()
        return self

    def transform(self, X):
        return np.delete(X, self.to_drop, axis=1)


# ✅ Aangepast voor LOO: geen per-fold AUC, maar één globale ROC over alle verzamelde voorspellingen
def plot_loo_roc(y_true, y_proba, title):
    fpr, tpr, _ = roc_curve(y_true, y_proba)
    roc_auc = auc(fpr, tpr)

    plt.figure(figsize=(7, 7))
    plt.plot(fpr, tpr, color="blue", lw=2.5,
             label=f"ROC curve (AUC = {roc_auc:.2f})")
    plt.plot([0, 1], [0, 1], linestyle="--", color="black", lw=2,
             label="Chance level (AUC = 0.5)")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title(f"LOO ROC curve\n{title}")
    plt.legend(loc="lower right")
    plt.grid(alpha=0.3)
    plt.show()

    return roc_auc


#%% Nested CV met LOO outer loop
# ✅ LOO outer: elke sample is 1x testset → geen AUC-variantie per fold, wel maximale trainsetgrootte
outer_cv = LeaveOneOut()

# ✅ Inner CV: StratifiedKFold blijft, want LOO heeft geen stratificatie nodig (1 testsample)
inner_cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)

results = []
roc_data = {}

for clf_name, clf in classifiers.items():
    feature_selection_methods = get_feature_selection_methods(clf, clf_name)

    for fs_name, fs in feature_selection_methods.items():
        print(f"Begonnen met de Nested CV van {clf_name} en {fs_name}")

        # Verzamel voorspellingen over alle LOO folds
        all_y_true = []
        all_y_proba = []
        all_inner_aucs = []

        try:
            for outer_fold, (outer_train_rijen, outer_test_rijen) in enumerate(outer_cv.split(X, y), start=1):

                X_outer_train = X.iloc[outer_train_rijen]
                X_outer_test = X.iloc[outer_test_rijen]
                y_outer_train = y[outer_train_rijen]
                y_outer_test = y[outer_test_rijen]

                pipeline = Pipeline([
                    ("scaler", RobustScaler()),
                    ("outliers", Clipper(0.01, 0.99)),
                    ("variance", VarianceThreshold(threshold=0.1)),
                    ("correlation", CorrelationFilter(threshold=0.8)),
                    ("feature_selection", clone(fs) if fs is not None else "passthrough"),
                    ("classifier", clone(clf))
                ])

                hyperparameter_grid = {f"classifier__{k}": v for k, v in hyperparameter_grids[clf_name].items()}

                # ✅ RandomizedSearchCV i.p.v. GridSearchCV: n_iter=50 i.p.v. alle combinaties
                # Met 115 outer folds is volledige GridSearch niet realistisch (115 × 810 × 5 = 465k fits voor RF)
                inner_loop = RandomizedSearchCV(
                    pipeline,
                    param_distributions=hyperparameter_grid,
                    n_iter=50,          # ✅ 50 random combinaties i.p.v. alle 810/432
                    cv=inner_cv,
                    scoring='roc_auc',
                    n_jobs=-1,
                    random_state=42,
                    error_score='raise'
                )

                inner_loop.fit(X_outer_train, y_outer_train)

                best_model = inner_loop.best_estimator_
                y_proba = best_model.predict_proba(X_outer_test)[:, 1]

                # ✅ Verzamelen voor globale AUC — niet per fold
                all_y_true.append(y_outer_test[0])
                all_y_proba.append(y_proba[0])
                all_inner_aucs.append(inner_loop.best_score_)

                if outer_fold % 10 == 0:
                    print(f"    {clf_name} + {fs_name} ==> fold {outer_fold}/{len(y)} afgerond")

            # Globale AUC berekenen over alle LOO voorspellingen
            all_y_true = np.array(all_y_true)
            all_y_proba = np.array(all_y_proba)

            fpr, tpr, _ = roc_curve(all_y_true, all_y_proba)
            global_auc = auc(fpr, tpr)
            mean_inner_auc = np.mean(all_inner_aucs)

            key = f"{clf_name} + {fs_name}"
            roc_data[key] = {
                "fpr": fpr,
                "tpr": tpr,
                "auc": global_auc,
                "y_true": all_y_true,
                "y_proba": all_y_proba
            }

            results.append({
                "Classifier": clf_name,
                "Feature Selection": fs_name,
                "LOO AUC": global_auc,
                "Mean Inner AUC": mean_inner_auc,
            })

            print(f"  ✓ {clf_name} + {fs_name} ==> LOO AUC = {global_auc:.3f} | Mean Inner AUC = {mean_inner_auc:.3f}")

        except Exception as e:
            results.append({
                "Classifier": clf_name,
                "Feature Selection": fs_name,
                "LOO AUC": float('nan'),
                "Mean Inner AUC": float('nan'),
            })
            print(f"  ✗ {clf_name} + {fs_name} ==> gefaald: {e}")

# Resultaten
results_df = pd.DataFrame(results).sort_values("LOO AUC", ascending=False)

print("\nSamenvatting gesorteerd op LOO AUC:")
print(results_df.to_string())

# ROC curves
for key, roc_dict in roc_data.items():
    plot_loo_roc(roc_dict["y_true"], roc_dict["y_proba"], key)

